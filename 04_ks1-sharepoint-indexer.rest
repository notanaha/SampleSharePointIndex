@api-key = {{$dotenv AZURE_SEARCH_API_KEY}}
@search-endpoint = {{$dotenv AZURE_SEARCH_ENDPOINT}}
@api-version = 2025-11-01-Preview

@name-prefix = {{$dotenv NAME_PREFIX}}
@indexer-name = {{name-prefix}}-indexer
@data-source-name = {{name-prefix}}-datasource
@skillset-name = {{name-prefix}}-skillset
@index-name = {{name-prefix}}-index

### Create indexer
PUT {{search-endpoint}}/indexers/{{indexer-name}}?api-version={{api-version}}
api-key: {{api-key}}
Content-Type: application/json

{
  "name": "{{indexer-name}}",
  "description": "Indexer for knowledge source '{{name-prefix}}'",
  "dataSourceName": "{{data-source-name}}",
  "skillsetName": "{{skillset-name}}",
  "targetIndexName": "{{index-name}}",
  "disabled": false,
  "schedule": null,
  "parameters": {
    "batchSize": null,
    "maxFailedItems": -1,
    "maxFailedItemsPerBatch": -1,
    "configuration": {
      "dataToExtract": "contentAndMetadata",
      "parsingMode": "default",
      "allowSkillsetToReadFileData": true
    }
  },
  "fieldMappings": [
    { "sourceFieldName": "metadata_user_ids",  "targetFieldName": "UserIds" },
    { "sourceFieldName": "metadata_group_ids", "targetFieldName": "GroupIds" }
  ],
  "outputFieldMappings": [],
  "cache": null,
  "encryptionKey": null
}

###

## Get indexer status (execution history + error details)
GET {{search-endpoint}}/indexers/{{indexer-name}}/status?api-version={{api-version}}
api-key: {{api-key}}

###

### Reset indexer
POST {{search-endpoint}}/indexers/{{indexer-name}}/reset?api-version={{api-version}}
api-key: {{api-key}}

###

### Run indexer
POST {{search-endpoint}}/indexers/{{indexer-name}}/run?api-version={{api-version}}
api-key: {{api-key}}
